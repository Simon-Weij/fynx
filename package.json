{
	"name": "electrobun-svelte",
	"version": "1.0.0",
	"type": "module",
	"description": "Electrobun app with Svelte and Vite HMR",
	"scripts": {
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite dev --port 5173",
		"start": "vite build && electrobun dev",
		"build:canary": "vite build && electrobun build --env=canary"
	},
	"dependencies": {
		"@sveltejs/kit": "^2.53.4",
		"@tailwindcss/vite": "^4.2.1",
		"electrobun": "1.15.1",
		"tailwindcss": "^4.2.1"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/vite-plugin-svelte": "^5.0.1",
		"@types/bun": "latest",
		"concurrently": "^9.1.0",
		"svelte": "^5.14.1",
		"typescript": "^5.7.2",
		"vite": "^6.0.3"
	}
}
